								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"source_account_id\": \"{{account_id}}\",\n    \"destination_account_id\": \"acc_another_456\",\n    \"amount\": 15000,\n    \"currency\": \"KZT\",\n    \"idempotency_key\": \"tx_key_{{$randomInt}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/transfers",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
