{
	"info": {
		"_postman_id": "8b5a0342-88d4-47c0-a7d5-d0df72bf9c85",
		"name": "Banking Service API",
		"description": "API collection for testing and demonstrating Banking Service gateway features.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Accounts",
			"item": [
				{
					"name": "Create Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.account_id) {",
									"    pm.collectionVariables.set(\"account_id\", jsonData.account_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customer_id\": \"user_99\",\n    \"currency\": \"KZT\",\n    \"idempotency_key\": \"create_acc_{{$randomInt}}\",\n    \"initial_balance\": 1000\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Account Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/{{account_id}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"{{account_id}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Deposit Money",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 50000,\n    \"idempotency_key\": \"dep_key_{{$randomInt}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/{{account_id}}/deposit",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"{{account_id}}",
								"deposit"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Account History",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/{{account_id}}/history?limit=10&offset=0",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"{{account_id}}",
								"history"
							],
							"query": [
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "offset",
									"value": "0"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Freeze Account",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"suspicious activity detected\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/{{account_id}}/freeze",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"{{account_id}}",
								"freeze"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Account Status (Unfreeze / Direct status edit)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"ACTIVE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/{{account_id}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"{{account_id}}",
								"status"
							]
						}
					},
					"response": []
				}
			]
		},
